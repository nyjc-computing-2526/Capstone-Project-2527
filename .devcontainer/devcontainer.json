{
    "name": "Python 3.12",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -r requirements.txt",
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python3"
            },
            "extensions": [
                "ms-python.python"
            ]
        }
    }
}
